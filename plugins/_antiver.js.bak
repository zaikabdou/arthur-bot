// ملف: plugins/_antiviewonce.js
// يعيد إرسال أي صورة/فيديو/صوت تم إرساله كـ "عرض مرة واحدة" بشكل عادي + حذف الأصلي
// يشتغل مع: .فتح مضاد_العرض   |   .قفل مضاد_العرض

import { downloadContentFromMessage } from '@whiskeysockets/baileys'

export async function before(m, { conn, isAdmin, isBotAdmin }) {
  if (!m.isGroup) return true
  if (m.fromMe || m.isBaileys) return true

  const chat = global.db.data?.chats?.[m.chat] || {}
  if (!chat.antiviewonce) return true

  // تحديد نوع الرسالة ViewOnce (الإصدارين V2 و V2Extension)
  const isViewOnce =
    m.mtype === 'viewOnceMessageV2' ||
    m.mtype === 'viewOnceMessageV2Extension'

  if (!isViewOnce) return true

  try {
    // استخراج الرسالة الفعلية داخل ViewOnce
    const msg = m.mtype === 'viewOnceMessageV2'
      ? m.message.viewOnceMessageV2.message
      : m.message.viewOnceMessageV2Extension.message

    const type = Object.keys(msg)[0] // imageMessage | videoMessage | audioMessage
    const mediaMessage = msg[type]

    if (!mediaMessage) return true

    // نوع الميديا للتحميل
    const streamType = 
      type === 'imageMessage' ? 'image' :
      type === 'videoMessage' ? 'video' : 'audio'

    // تحميل الملف
    const stream = await downloadContentFromMessage(mediaMessage, streamType)
    let buffer = Buffer.from([])
    for await (const chunk of stream) {
      buffer = Buffer.concat([buffer, chunk])
    }

    // حساب الحجم
    const fileSize = mediaMessage.fileLength?.low || mediaMessage.fileLength || buffer.length
    const size = formatFileSize(fileSize)

    // نص الوصف
    const caption = `
ممنوع إرسال شيء للعرض مرة واحدة

النوع: ${type === 'imageMessage' ? 'صورة' : type === 'videoMessage' ? 'فيديو' : 'تسجيل صوتي'}
الفاعل: @${m.sender.split('@')[0]}
\( {mediaMessage.caption ? `الكتابة: \){mediaMessage.caption}` : ''}
الحجم: ${size}
`.trim()

    // حذف الرسالة الأصلية (ViewOnce)
    if (isBotAdmin) {
      await conn.sendMessage(m.chat, {
        delete: { remoteJid: m.chat, fromMe: false, id: m.key.id, participant: m.sender }
      }).catch(() => {})
    }

    // إعادة الإرسال بشكل عادي
    if (type === 'imageMessage') {
      await conn.sendMessage(m.chat, {
        image: buffer,
        caption,
        mentions: [m.sender]
      }, { quoted: m })
    }

    else if (type === 'videoMessage') {
      await conn.sendMessage(m.chat, {
        video: buffer,
        caption,
        gifPlayback: mediaMessage.gifPlayback || false,
        mentions: [m.sender]
      }, { quoted: m })
    }

    else if (type === 'audioMessage') {
      await conn.sendMessage(m.chat, {
        audio: buffer,
        mimetype: 'audio/mpeg',
        ptt: true,               // صوت بصيغة الـ Voice Note
        waveform: mediaMessage.waveform || null
      }, { quoted: m })

      await conn.sendMessage(m.chat, {
        text: caption,
        mentions: [m.sender]
      }, { quoted: m })
    }

  } catch (err) {
    console.error('خطأ في مضاد العرض مرة واحدة:', err)
  }

  return true
}

// دالة تحويل الحجم للوحدات البشرية
function formatFileSize(bytes) {
  if (!bytes || bytes === 0) return '0 بايت'
  const sizes = ['بايت', 'كيلوبايت', 'ميغابايت', 'غيغابايت', 'تيرابايت']
  const i = Math.floor(Math.log(bytes) / Math.log(1024))
  return `\( {(bytes / Math.pow(1024, i)).toFixed(2)} \){sizes[i]}`
}

export default {
  help: ['فتح', 'قفل'],
  tags: ['group'],
  command: /^(فتح|قفل|enable|disable)$/i,
  group: true,
  admin: true
}