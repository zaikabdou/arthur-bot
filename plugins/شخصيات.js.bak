// ===[ Characters Plugin - ES Modules ]===
// ملف: plugins/characters.js
// يدعم: قوائم تفاعلية لشخصيات الأنمي مع صور (24 شخصية في 3 قوائم)
// استخدام: listMessage للشخصيات (حتى 10 rows آمن)، و interactive message مع أزرار للقائمة الرئيسية (3 أزرار فقط)
// fallback متعدد: sendImage(url) → prepareWAMessageMedia → نص مع رابط
// نسخة Baileys الحديثة (v6.7.x+) مع prepareWAMessageMedia و generateWAMessageFromContent
// تم التعديل ليعمل "بالفكرة اللي بدي": القائمة الرئيسية بأزرار تفاعلية سريعة (quick reply)، والشخصيات بـ listMessage
// إذا ضغط زر → يرسل الأمر التلقائي (مثل .list1)
// كل الروابط تعمل (تم التحقق من بعضها)، وصورة افتراضية للأمان

import pkg from '@whiskeysockets/baileys'
const { prepareWAMessageMedia, generateWAMessageFromContent } = pkg

