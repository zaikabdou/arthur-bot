// ===[ AntiBot + DetectBot Ultimate 2026 ]===
// ملف واحد فقط: يطرد البوتات + يكشف أي رقم عليه بوت شغال (حتى لو مقفول أو ما يرد)
// يشتغل مع:
// .فتح مضاد_البوت    → يطرد البوتات ويكشف الخفية
// .قفل مضاد_البوت

import { areJidsSameUser } from '@whiskeysockets/baileys'

export async function before(m, { conn, participants, isBotAdmin, isAdmin, isOwner }) {
  if (!m.isGroup || m.fromMe || m.isBaileys) return true

  const chat = global.db.data.chats[m.chat]
  const enableAntiBot = chat.antiBot || false // للطرد والحذف
  const enableDetectBot = chat.detectBot || false // للكشف فقط (اختياري)

  if (!enableAntiBot && !enableDetectBot) return true

  // البوت الرئيسي (ما يطرد نفسه ولا يكشفه)
  const mainBotJid = global.conn?.user?.jid || global.owner?.[0]?.[0] + '@s.whatsapp.net'
  if (areJidsSameUser(m.sender, mainBotJid)) return true

  // لو البوت فرعي وشاف الرئيسي → يطلع فورًا
  if (!areJidsSameUser(conn.user.jid, mainBotJid) && 
      participants.some(p => areJidsSameUser(p.id, mainBotJid))) {
    if (enableAntiBot) setTimeout(() => conn.groupLeave(m.chat), 4000)
    return true
  }

  // لو البوت مش رئيسي أو مش أدمن → ما يطرد (لكن ممكن يكشف)
  const canKick = areJidsSameUser(conn.user.jid, mainBotJid) && isBotAdmin

  let detected = false
  let reason = ''

  // === 1 === الكشف بالـ ID السحري (3EB0 + 22) → بوت Baileys مكشوف 100%
  const isBaileysID = m.key?.id?.startsWith('3EB0') && m.key?.id?.length === 22

  // === 2 === الكشف بالبصمة التقنية (StubType) → بوت شغال حتى لو مقفول
  const baileysStubs = [68, 87, 91, 92, 94]
  const isBaileysStub = m.messageStubType && baileysStubs.includes(m.messageStubType)

  // === 3 === الكشف الذكي بالسلوك (إضافي)
  if (!global.antiBotDB) global.antiBotDB = {}
  const db = global.antiBotDB[m.chat] = global.antiBotDB[m.chat] || {}
  const user = db[m.sender] = db[m.sender] || { msgs: [], last: 0, instant: 0 }

  const now = Date.now()
  const timeDiff = now - user.last
  const text = (m.text || '').toLowerCase()
  const hasPrefix = /^[\.\!\*\#\-\_\/\|]/.test(text.trim())

  user.msgs.push({ text, time: now })
  if (user.msgs.length > 12) user.msgs.shift()
  user.last = now

  if (timeDiff > 0 && timeDiff < 400) user.instant++
  else user.instant = 0

  const last5 = user.msgs.slice(-5).map(x => x.text)
  const unique5 = [...new Set(last5)]
  const sameFormat = user.msgs.slice(-6).map(x => `\( {x.text.split('\n').length}- \){(x.text.match(/\p{Emoji}/gu) || []).length}`)
  const uniqueFormat = [...new Set(sameFormat)]

  const isSuspiciousBehavior = 
    user.instant > 5 ||
    hasPrefix ||
    (last5.length >= 5 && unique5.length <= 2) ||
    (sameFormat.length >= 6 && uniqueFormat.length <= 2)

  // === تحديد إذا كان بوت ===
  if (isBaileysID) {
    detected = true
    reason = 'بوت Baileys مكشوف (3EB0 ID)'
  } else if (isBaileysStub) {
    detected = true
    reason = `بوت شغال حاليًا (بصمة تقنية: ${m.messageStubType})`
  } else if (isSuspiciousBehavior) {
    detected = true
    reason = 'سلوك آلي مشبوه (رد فوري + نمط ثابت)'
  }

  // === إذا تم الكشف ===
  if (detected) {
    const name = conn.getName(m.sender) || m.sender.split('@')[0]

    const caption = `
تم اكتشاف بوت في المجموعة
الاسم: ${name}
الرقم: ${m.sender.split('@')[0]}
السبب: ${reason}
البوت الوحيد المسموح: أنا فقط
    `.trim()

    // إرسال التنبيه
    await conn.sendMessage(m.chat, { text: caption, mentions: [m.sender] })

    // إذا مفعل الطرد + البوت أدمن → يطرد
    if (enableAntiBot && canKick) {
      try {
        // حذف الرسالة
        await conn.sendMessage(m.chat, {
          delete: { remoteJid: m.chat, fromMe: false, id: m.key.id, participant: m.sender }
        })

        // طرد البوت
        await conn.groupParticipantsUpdate(m.chat, [m.sender], 'remove')
        await conn.sendMessage(m.chat, { text: `تم طرد البوت بنجاح\nالجروب آمن 100%` })

        // تنظيف السجل
        delete db[m.sender]
      } catch (e) {
        console.error('فشل الطرد:', e)
      }
    }
  }

  return true
}